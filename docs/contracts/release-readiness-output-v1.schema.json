{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/psuthar/release-readiness-core/schemas/release-readiness-output-v1.schema.json",
  "title": "Release Readiness Output v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "passed",
    "warnings",
    "blocked",
    "validations"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "WARN",
        "BLOCK"
      ]
    },
    "passed": {
      "type": "integer",
      "minimum": 0
    },
    "warnings": {
      "type": "integer",
      "minimum": 0
    },
    "blocked": {
      "type": "integer",
      "minimum": 0
    },
    "validations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key",
          "status"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "WARN",
              "BLOCK"
            ]
          },
          "detail": {
            "type": "string"
          }
        }
      }
    }
  }
}
