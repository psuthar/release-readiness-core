{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/psuthar/release-readiness-core/schemas/pr-risk-input-v1.schema.json",
  "title": "PR Risk Input v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "recommendation",
    "score"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "recommendation": {
      "type": "string",
      "enum": [
        "PASS",
        "WARN",
        "BLOCK"
      ]
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "summary": {
      "type": "string"
    },
    "factors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key",
          "weight",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "value": {
            "type": "number"
          },
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "WARN",
              "BLOCK"
            ]
          },
          "detail": {
            "type": "string"
          }
        }
      }
    }
  }
}
